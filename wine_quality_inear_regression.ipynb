"# STEP 4: Model Evaluation\n",
"predictions = model.predict(X_test)\n",
"mse = np.mean((predictions - y_test)**2)\n",
"print(f"Test Set Mean Squared Error: {mse:.4f}")\n",
"print(f"Root Mean Squared Error: {np.sqrt(mse):.4f}")"
]
},
